<Window x:Class="ONESolutionUtility_v1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ONESolution Installer Utility"
        Height="840" Width="960"
        MinHeight="700" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,4,4,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4,12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4,8,8"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1E3A5F" Padding="14,10">
            <TextBlock Text="ONESolution Installer Utility"
                       Foreground="White" FontSize="17" FontWeight="Bold"/>
        </Border>

        <!-- Bottom: Log + Buttons -->
        <Grid DockPanel.Dock="Bottom">
            <Grid.RowDefinitions>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <GroupBox Header="Output Log" Margin="4,4,4,0">
                <RichTextBox x:Name="RichTxtLog" IsReadOnly="True"
                             FontFamily="Consolas" FontSize="11"
                             VerticalScrollBarVisibility="Auto"
                             Background="#1E1E1E" Foreground="#DCDCDC"
                             BorderThickness="0"/>
            </GroupBox>

            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="8,4,8,8">
                <Button x:Name="BtnClear" Content="Clear Log"
                        Width="90" Height="28" Margin="0,0,8,0"
                        Click="BtnClear_Click"/>
                <Button x:Name="BtnInstall" Content="Run Install"
                        Width="130" Height="28"
                        Background="#1E3A5F" Foreground="White"
                        FontWeight="Bold" Click="BtnInstall_Click"/>
            </StackPanel>
        </Grid>

        <!-- Main config (scrollable) -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="4">

                <!-- Row 1: Customer type + App toggles -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Customer Type">
                        <StackPanel>
                            <CheckBox x:Name="ChkCloudCustomer" Content="Cloud Customer"
                                      IsChecked="True" FontWeight="SemiBold"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Applications to Install">
                        <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <CheckBox x:Name="ChkRms"   Content="RMS"   IsChecked="True"  Width="90"/>
                            <CheckBox x:Name="ChkJms"   Content="JMS"   IsChecked="False" Width="90"/>
                            <CheckBox x:Name="ChkMfr"   Content="MFR"   IsChecked="True"  Width="90"/>
                            <CheckBox x:Name="ChkCad"   Content="CAD"   IsChecked="False" Width="90"/>
                            <CheckBox x:Name="ChkOsmct" Content="OSMCT" IsChecked="True"  Width="90"/>
                        </WrapPanel>
                    </GroupBox>
                </Grid>

                <!-- Row 2: Network paths (left) + Local/CAD paths (right) -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <GroupBox Header="Network Paths">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0">Shortcut Destination</Label>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtShortcutPath"
                                     Text="C:\Users\Public\Desktop"/>

                            <Label Grid.Row="1" Grid.Column="0">RMS / JMS App Path</Label>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtRmsJmsPath"/>

                            <Label Grid.Row="2" Grid.Column="0">Moblan Path (MFR)</Label>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMoblanPath"/>

              <Label Grid.Row="3" Grid.Column="0">Mupdate Path (OSMCT)</Label>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtMupdatePath"/>

                            <Label Grid.Row="4" Grid.Column="0">OSMCT Installer Path</Label>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtOsmctInstallPath"/>

                            <Label Grid.Row="5" Grid.Column="0">Shared Path</Label>
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtSharedPath"
                                     ToolTip="Folder containing: ONESolution RMS and JMS Components.msi, msodbcsql64_17.msi, vc_redist.x64.exe"/>

                            <Label Grid.Row="6" Grid.Column="0">Report Viewer Path</Label>
                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="TxtReportViewerPath"/>
                        </Grid>
                    </GroupBox>

                    <GroupBox Grid.Column="1" Header="Local Folders &amp; CAD Paths">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="170"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Label Grid.Row="0" Grid.Column="0">Superion Folder</Label>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtSuperionPath"
                                     Text="C:\ProgramData\Superion"/>

                            <Label Grid.Row="1" Grid.Column="0">Mobfiles Folder</Label>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtMobfilesPath"
                                     Text="C:\mobfiles"/>

                            <Label Grid.Row="2" Grid.Column="0">Foxtmp Folder</Label>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtFoxtmpPath"
                                     Text="C:\foxtmp"/>

                            <Label Grid.Row="3" Grid.Column="0">Ossimob Folder</Label>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtOssimobPath"
                                     Text="C:\ossimob"/>

                            <Label Grid.Row="4" Grid.Column="0">CAD Path (on-prem)</Label>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtCadPath"/>

                            <Label Grid.Row="5" Grid.Column="0">CAD Cloud Installer</Label>
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="TxtCadCloudPath"/>
                        </Grid>
                    </GroupBox>
                </Grid>

                <!-- Row 3: Shortcut Names -->
                <GroupBox Header="Shortcut Names">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Width="60">RMS</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtRmsName"      Text="ONESolution RMS"/>
                        <Label Grid.Row="0" Grid.Column="3" Width="80">Cloud RMS</Label>
                        <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtRmsCloudName" Text="ONESolution Cloud RMS"/>

                        <Label Grid.Row="1" Grid.Column="0" Width="60">JMS</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtJmsName"      Text="ONESolution JMS"/>
                        <Label Grid.Row="1" Grid.Column="3" Width="80">Cloud JMS</Label>
                        <TextBox Grid.Row="1" Grid.Column="4" x:Name="TxtJmsCloudName" Text="ONESolution Cloud JMS"/>

                        <Label Grid.Row="2" Grid.Column="0" Width="60">MFR</Label>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMfrName"      Text="ONESolution MFR"/>
                        <Label Grid.Row="2" Grid.Column="3" Width="80">Cloud MFR</Label>
                        <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtMfrCloudName" Text="ONESolution Cloud MFR"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="OSMCT / CAD Shortcut Names">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Width="60">OSMCT</Label>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtOsmctName"      Text="ONESolution MCT"/>
                        <Label Grid.Row="0" Grid.Column="3" Width="80">Cloud OSMCT</Label>
                        <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtOsmctCloudName" Text="ONESolution Cloud MCT"/>

                        <Label Grid.Row="1" Grid.Column="0" Width="60">CAD</Label>
                        <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCadName" Text="ONESolution CAD"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
