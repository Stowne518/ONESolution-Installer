<Window x:Class="ONESolutionUtility_v1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ONESolution Installer Utility" Width="960" Height="850"
        MinHeight="700" MinWidth="800"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Padding" Value="4,3"/>
            <Setter Property="Height" Value="23.96"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,4,4,0"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="4,4,12,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,4,8,8"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="#1E3A5F" Padding="14,10">
			<TextBlock Text="ONESolution Installer Utility"
                       Foreground="White" FontSize="17" FontWeight="Bold"/>
        </Border>

        <TabControl>

            <!-- ═══════════════════════ Workstation Installation ═══════════════════════ -->
            <TabItem Header="Workstation Installation">
                <DockPanel>

                    <!-- Bottom: Log + Buttons -->
                    <Grid DockPanel.Dock="Bottom">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="180" />
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <GroupBox Header="Output Log" Margin="4,4,4,0">
                            <RichTextBox x:Name="RichTxtLog" IsReadOnly="True"
                                         FontFamily="Consolas" FontSize="11"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="#1E1E1E" Foreground="#DCDCDC"
                                         BorderThickness="0"/>
                        </GroupBox>

                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="8,4,8,8">
                            <Button x:Name="BtnClear" Content="Clear Log"
                                    Width="90" Height="28" Margin="0,0,8,0"
                                    Click="BtnClear_Click"/>
                            <Button x:Name="BtnInstall" Content="Run Install"
                                    Width="130" Height="28"
                                    Background="#1E3A5F" Foreground="White"
                                    FontWeight="Bold" Click="BtnInstall_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Main config (scrollable) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="4">

                            <!-- Row 1: Customer type + App toggles -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <GroupBox Header="Customer Type">
                                    <StackPanel>
                                        <CheckBox x:Name="ChkCloudCustomer" Content="Cloud Customer"
                                                  IsChecked="True" FontWeight="SemiBold" IsEnabled="True"
                                                  Checked="ChkCloudCustomer_Checked"
                                                  Unchecked="ChkCloudCustomer_Unchecked"/>
                                    </StackPanel>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Header="Applications to Install">
                                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <CheckBox x:Name="ChkRms"   Content="RMS"   IsChecked="False" Width="90"/>
                                        <CheckBox x:Name="ChkJms"   Content="JMS"   IsChecked="False" Width="90"/>
                                        <CheckBox x:Name="ChkMfr"   Content="MFR"   IsChecked="False" Width="90"/>
                                        <CheckBox x:Name="ChkCad"   Content="CAD"   IsChecked="False" Width="90"/>
                                        <CheckBox x:Name="ChkOsmct" Content="OSMCT" IsChecked="False" Width="90"/>
                                    </WrapPanel>
                                </GroupBox>
                            </Grid>

                            <!-- FileSync / FileShare server row -->
                            <GroupBox x:Name="FileServerGroup" Header="FileSync" Margin="4,4,4,4">
                                <Grid x:Name="FileSyncServerGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="600"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="24"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Column="0">Server FQDN</Label>
									<TextBox Grid.Column="1" x:Name="FileServerFQDN" Margin="0,0,10,0" IsEnabled="True" Text=""/>
                                    <Button Grid.Column="2" x:Name="GenFilePaths" Content="Fill Paths"
											IsEnabled="True"
                                            Width="70" Height="24"
                                            Background="#1E3A5F" Foreground="White"
                                            FontWeight="Bold" Click="GenFilePaths_Click"/>
                                    <Label  Grid.Column="3" Grid.ColumnSpan="2" x:Name="RmsLabel" Margin="10,0,0,0" Visibility="Collapsed">RMS Folder</Label>
                                    <TextBox Grid.Column="4" x:Name="TxtRMSFolder" Visibility="Collapsed"/>
                                    <Label  Grid.Column="5" Grid.ColumnSpan="2" x:Name="CadLabel" Margin="10,0,0,0" Visibility="Collapsed">CAD Folder</Label>
                                    <TextBox Grid.Column="6" x:Name="TxtCADFolder" Visibility="Collapsed"/>
                                </Grid>
                            </GroupBox>

                            <!-- Row 2: Network paths (left) + Local paths + OSMCT Cloud Prep (right) -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <GroupBox Header="Network Paths" Grid.Row="0" Grid.RowSpan="2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="63"/>
                                            <ColumnDefinition Width="107"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                            <RowDefinition Height="30"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">RMS / JMS App Path</Label>
										<TextBox Grid.Row="0" Grid.Column="2" x:Name="TxtRmsJmsPath" IsEnabled="True" Margin="0,2,0,4"/>

                                        <Label Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">Moblan Path (MFR)</Label>
										<TextBox Grid.Row="1" Grid.Column="2" x:Name="TxtMoblanPath" IsEnabled="True" Margin="0,2,0,4"/>

                                        <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">Mupdate Path (OSMCT)</Label>
										<TextBox Grid.Row="2" Grid.Column="2" x:Name="TxtMupdatePath" IsEnabled="True" Margin="0,2,0,4"/>

                                        <Label Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">OSMCT Installer Path</Label>
										<TextBox Grid.Row="3" Grid.Column="2" x:Name="TxtOsmctInstallPath" Text="" IsEnabled="True" Margin="0,2,0,4"/>

                                        <Label Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">Shared Path</Label>
										<TextBox Grid.Row="4" Grid.Column="2" x:Name="TxtSharedPath" IsEnabled="True"
                                                 ToolTip="Folder containing: ONESolution RMS and JMS Components.msi, msodbcsql64_17.msi, vc_redist.x64.exe"
                                                 Margin="0,2,0,4"/>

                                        <Label Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,0,0,30" Grid.RowSpan="2">CAD Path</Label>
										<TextBox Grid.Row="5" Grid.Column="2" x:Name="TxtCadPath" Margin="0,2,0,4" IsEnabled="True"/>

                                        <Label Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2">Report Viewer Path</Label>
										<TextBox Grid.Row="6" Grid.Column="2" x:Name="TxtReportViewerPath" Margin="0,2,0,4" IsEnabled="True"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Grid.Row="0" Header="Local Folders">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="170"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Label Grid.Row="0" Grid.Column="0">Shortcut Destination</Label>
										<TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtShortcutPath" IsEnabled="True"
                                                 Text="C:\Users\Public\Desktop"/>

                                        <Label Grid.Row="1" Grid.Column="0">Superion Folder</Label>
										<TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtSuperionPath" IsEnabled="True"
                                                 Text="C:\ProgramData\Superion"/>

                                        <Label Grid.Row="2" Grid.Column="0">Mobfiles Folder</Label>
                                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMobfilesPath" IsEnabled="True"
                                                 Text="C:\mobfiles"/>

                                        <Label Grid.Row="3" Grid.Column="0">Foxtmp Folder</Label>
										<TextBox Grid.Row="3" Grid.Column="1" x:Name="TxtFoxtmpPath" IsEnabled="True"
                                                 Text="C:\foxtmp"/>

                                        <Label Grid.Row="4" Grid.Column="0">Ossimob Folder</Label>
										<TextBox Grid.Row="4" Grid.Column="1" x:Name="TxtOssimobPath" IsEnabled="True"
                                                 Text="C:\ossimob"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Grid.Column="1" Grid.Row="1" Header="OSMCT Cloud Prep">
                                    <Grid x:Name="GridOsmctConfigure">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

										<Button Grid.Column="0"
                                                Width="150" Height="28"
                                                Background="#1E3A5F" Foreground="White"
                                                FontWeight="Bold"
												IsEnabled="True"
												x:Name="BtnPreInstallCloudOsmct"
                                                Content="Pre-Install Cloud OSMCT"
                                                ToolTip="Please use the migration tab for ossimob installation."/>
										<Button Grid.Column="1"
                                                Width="150" Height="28"
                                                Background="#1E3A5F" Foreground="White"
												x:Name="BtnInstallCloudOsmct"
												IsEnabled="True"
                                                FontWeight="Bold"
                                                Content="Install Cloud OSMCT"
                                                ToolTip="Please use the migration tab for ossimob installation."/>
                                    </Grid>
                                </GroupBox>
                            </Grid>

                            <!-- Row 3: Shortcut Names -->
                            <GroupBox Header="Shortcut Names">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Width="60">RMS</Label>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtRmsName"      Text="ONESolution RMS"/>
                                    <Label Grid.Row="0" Grid.Column="3" Width="80">Cloud RMS</Label>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtRmsCloudName" Text="ONESolution Cloud RMS"/>

                                    <Label Grid.Row="1" Grid.Column="0" Width="60">JMS</Label>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtJmsName"      Text="ONESolution JMS"/>
                                    <Label Grid.Row="1" Grid.Column="3" Width="80">Cloud JMS</Label>
                                    <TextBox Grid.Row="1" Grid.Column="4" x:Name="TxtJmsCloudName" Text="ONESolution Cloud JMS"/>

                                    <Label Grid.Row="2" Grid.Column="0" Width="60">MFR</Label>
                                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="TxtMfrName"      Text="ONESolution MFR"/>
                                    <Label Grid.Row="2" Grid.Column="3" Width="80">Cloud MFR</Label>
                                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="TxtMfrCloudName" Text="ONESolution Cloud MFR"/>
                                </Grid>
                            </GroupBox>

                            <GroupBox Header="OSMCT / CAD Shortcut Names">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Grid.Row="0" Grid.Column="0" Width="60">OSMCT</Label>
                                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="TxtOsmctName"      Text="ONESolution MCT"/>
                                    <Label Grid.Row="0" Grid.Column="3" Width="80">Cloud OSMCT</Label>
                                    <TextBox Grid.Row="0" Grid.Column="4" x:Name="TxtOsmctCloudName" Text="ONESolution Cloud MCT"/>

                                    <Label Grid.Row="1" Grid.Column="0" Width="60">CAD</Label>
                                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="TxtCadName" Text="ONESolution CAD"/>
                                </Grid>
                            </GroupBox>

                        </StackPanel>
                    </ScrollViewer>

                </DockPanel>
            </TabItem>
			
			<!-- ═══════════════════════ Migration Processes ═══════════════════════ -->
			<TabItem x:Name="Migrationtabwindow" Header="Migration">
				<DockPanel>
					 <!--Bottom: Log + Buttons--> 
					<Grid DockPanel.Dock="Bottom">
						
						<Grid.RowDefinitions>
							<RowDefinition Height="180" />
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<GroupBox Header="Output Log" Margin="4,4,4,0">
							<RichTextBox x:Name="MigrationRichTxtLog" IsReadOnly="True"
                                 FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="#1E1E1E" Foreground="#DCDCDC"
                                 BorderThickness="0"/>      
						</GroupBox>

						<StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Right" Margin="8,4,8,8">
							<Button x:Name="Migration_BtnClear" Content="Clear Log"
                                Width="90" Height="28" Margin="0,0,8,0"
                                Click="BtnClear_Click"/>
						</StackPanel>
					</Grid>
					
					 <!--Main migration tab--> 
					<ScrollViewer VerticalScrollBarVisibility="Auto">
					    <StackPanel Margin="4">
							 <!--Ossimob Cloud pre-install and Rename--> 
						    <GroupBox Header="OSMCT Cloud Prep" Height="110">
							    <Grid DockPanel.Dock="Top" x:Name="MigrationGridOsmctConfigure" >
								    <Grid.ColumnDefinitions>
									    <ColumnDefinition Width="*"/>
									    <ColumnDefinition Width="*"/>
								    </Grid.ColumnDefinitions>

									<Grid.RowDefinitions>
										<RowDefinition Height="40"/>
										<RowDefinition Height="Auto"/>
									</Grid.RowDefinitions>
									<Grid x:Name="Migration_Ossimob_layout" Height="40" Grid.Row="0" Grid.Column="0">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="100"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Label Content="Ossimob Path" Grid.Column="0" Padding="4,9"/>
										<TextBox x:Name="Migration_Txtossimobpath" Grid.Column="1" 
												 Text="C:\ossimob"/>
									</Grid>
									<Button Grid.Column="0" Grid.Row="1"
											x:Name="Migration_BtnPreInstallCloudOsmct"
                                            Width="150" Height="28"
                                            Background="#1E3A5F" Foreground="White"
                                            FontWeight="Bold" Click="BtnPreInstallCloudOsmct_Click"
                                            Content="Pre-Install Cloud OSMCT"
                                            ToolTip="Run mupdate in preparation for a cloud migration. Will create a new C:\ossimob_cloud folder for go-live day."/>
									<Grid x:Name="Migration_Ossimob_cloud_layout" Height="40" Grid.Row="0" Grid.Column="1">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="100"/>
											<ColumnDefinition Width="*"/>
										</Grid.ColumnDefinitions>
										<Label Content="Cloud mobile path" Grid.Column="0" Padding="4,9,0,2"/>
										<TextBox x:Name="Migration_Txtossimobcloudpath" Grid.Column="1" 
									 Text="C:\ossimob_cloud"/>
									</Grid>
									<Button Grid.Column="1" Grid.Row="1"
											x:Name="Migration_BtnInstallCloudOsmct"
                                            Width="150" Height="28"
                                            Background="#1E3A5F" Foreground="White"
                                            FontWeight="Bold" Click="BtnInstallCloudOsmct_Click"
                                            Content="Install Cloud OSMCT"
                                            ToolTip="Rename the ossimob folder to ossimob_backup, rename ossimob_cloud to ossimob."/>
							    </Grid>
						    </GroupBox>
					    </StackPanel>
					</ScrollViewer>
				</DockPanel>
			</TabItem>
        </TabControl>
    </DockPanel>
</Window>
